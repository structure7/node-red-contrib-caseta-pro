{
  "root": true,
  "env": {
    "node": true,
    "es2021": true,
    "mocha": true
  },
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "script"
  },
  "extends": "eslint:recommended",
  "plugins": ["html"],
  "rules": {
    "no-unused-vars": ["warn", { "args": "none" }]
  },
  "overrides": [
    {
      "files": ["*.html"],
      "env": { "browser": true, "jquery": true, "node": false },
      "globals": { "RED": "readonly" },
      "rules": {
        "no-unused-vars": "off"
      }
    }
  ]
}
